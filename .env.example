# Copy to .env and fill in your values. Do not commit .env.

# Firebase (required for Sign In / Sign Up)
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Grok bridge (optional — for in-app Health Coach agent)
# URL of your Fortress Grok bridge, e.g. https://bridge.howell-forge.com (VPS + Caddy)
# Coach TTS uses the same host: POST /coach/tts (ElevenLabs key on server only — set ELEVENLABS_API_KEY in bridge env)
# Local laptop dev: EXPO_PUBLIC_GROK_BRIDGE_URL=http://127.0.0.1:5000
# Production (Play + hosted web): EXPO_PUBLIC_GROK_BRIDGE_URL=https://bridge.howell-forge.com
EXPO_PUBLIC_GROK_BRIDGE_URL=
