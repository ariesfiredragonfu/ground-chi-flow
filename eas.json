{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_GROK_BRIDGE_URL": "http://127.0.0.1:5000"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_GROK_BRIDGE_URL": "https://bridge.howell-forge.com"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "env": {
        "EXPO_PUBLIC_GROK_BRIDGE_URL": "https://bridge.howell-forge.com"
      },
      "android": {
        "buildType": "app-bundle",
        "autoIncrement": "versionCode"
      }
    }
  },
  "submit": {
    "production": {
      "android": {
        "serviceAccountKeyPath": "/home/christopher-c-howell/.config/google/google-credentials.json",
        "track": "internal",
        "releaseStatus": "completed"
      }
    }
  }
}
